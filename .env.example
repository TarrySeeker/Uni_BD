# =============================================================================
# Admik — шаблон конфигурации магазина
# =============================================================================
# Скопируйте этот файл в .env и заполните значения под конкретный магазин.
#   cp .env.example .env
# Файл .env НЕ коммитится в репозиторий (см. .gitignore).
# Принцип: 1 магазин = 1 БД = 1 конфигурация. Код не меняется между магазинами.
# =============================================================================

# Окружение Node: development | test | production
NODE_ENV=development

# -----------------------------------------------------------------------------
# Домен и SSL (Caddy reverse-proxy) — ОДИН VPS, ДВА ДОМЕНА (схема поддоменов)
# -----------------------------------------------------------------------------
# Топология (docs/09, docs/13): на одном сервере живут две части под ОДНИМ
# личным доменом:
#   • витрина магазина → SHOP_DOMAIN (+ www)        — публичный сайт магазина;
#   • Admik (админка/API/медиа) → ADMIN_DOMAIN      — поддомен admin.<домен>.
# DNS: A-записи apex (SHOP_DOMAIN), www и admin → один и тот же IP VPS.
# При реальных доменах Caddy сам получит TLS-сертификаты (HTTPS из коробки).
#
# Домен витрины (apex). Для локального запуска можно оставить localhost —
# тогда работает доступ по http://localhost через порт :80 (fallback → витрина).
SHOP_DOMAIN=localhost
# Поддомен админки/API/медиа Admik. Для боя — admin.<ваш-домен> (напр.
# admin.myshop.ru). Если НЕ задан, compose подставит admin.localhost (тогда
# отдельный домен Admik фактически не используется — одиночный-домен сценарий).
ADMIN_DOMAIN=admin.localhost
# Email для уведомлений Let's Encrypt (рекомендуется указать реальный).
ACME_EMAIL=admin@example.com

# -----------------------------------------------------------------------------
# База данных (PostgreSQL 15+)
# -----------------------------------------------------------------------------
# Учётные данные СУПЕРПОЛЬЗОВАТЕЛЯ контейнера postgres (docker-compose).
# ВНИМАНИЕ: в образе postgres роль POSTGRES_USER — это СУПЕРПОЛЬЗОВАТЕЛЬ БД.
# Она используется ТОЛЬКО для инициализации (init-shop: создание ролей и
# расширений) и для бэкапов/восстановления — НО НЕ для рантайма приложения.
POSTGRES_USER=admik
# ВНИМАНИЕ: замените на надёжный пароль перед боевым запуском.
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=admik

# Пароли служебных ролей БД (ADR-002/ADR-006, docs/04 §3.4). Создаются при
# инициализации (init-shop.sh) суперпользователем; пароли передаются в psql.
# ОБЯЗАТЕЛЬНО смените оба перед боевым запуском.
#   • admik_app      — роль РАНТАЙМА приложения: только точечный DML (least-privilege).
#                      На audit_log выданы лишь SELECT/INSERT (журнал неизменяем
#                      на уровне прав СУБД, append-only, миграция 0004/ADR-006).
#   • admik_migrator — роль НАКАТА миграций (DDL): владеет создаваемыми таблицами
#                      и выдаёт точечные GRANT роли admik_app.
APP_PASSWORD=change-me-app-password
MIGRATOR_PASSWORD=change-me-migrator-password

# Строка подключения РАНТАЙМА приложения. У каждого магазина — своя отдельная БД.
# КРИТИЧНО ДЛЯ БЕЗОПАСНОСТИ (least-privilege, ADR-002/ADR-006): приложение ходит в
# БД под ролью admik_app (минимальные права), НЕ под суперпользователем. Поэтому
# здесь — admik_app:${APP_PASSWORD}. Пароль ДОЛЖЕН совпадать с APP_PASSWORD выше.
#   • Суперпользователь (POSTGRES_USER) — только init-shop и бэкап/restore.
#   • Миграции (DDL) накатываются под admik_migrator (init-shop делает это сам).
# Внутри docker-сети хост БД — это имя сервиса 'postgres'.
# Локально (без Docker) используйте host=localhost.
DATABASE_URL=postgres://admik_app:change-me-app-password@postgres:5432/admik

# -----------------------------------------------------------------------------
# Владелец магазина (seed при инициализации, docs/04 §4.2)
# -----------------------------------------------------------------------------
# Email учётной записи владельца (супер-пользователь, is_owner). Создаётся
# скриптом init-shop один раз; повторный запуск ничего не меняет (идемпотентно).
OWNER_EMAIL=owner@example.com
# Пароль владельца. ОСТАВЬТЕ ПУСТЫМ ДЛЯ АВТОГЕНЕРАЦИИ — тогда init-shop
# сгенерирует надёжный пароль и напечатает его ОДИН РАЗ в консоль; смените
# при первом входе. Если задаёте вручную — используйте длинный случайный пароль.
OWNER_PASSWORD=

# Выделенный секрет HMAC токена доступа к заказу (m10). Развязывает токен заказа от
# пароля админки. Если пусто — фолбэк на APP_PASSWORD; в production без любого секрета
# генерация токена БРОСАЕТ (fail-closed). Длинная случайная строка.
ORDER_TOKEN_SECRET=

# -----------------------------------------------------------------------------
# Redis (кеш и rate-limit, нужен для горизонтального масштабирования)
# -----------------------------------------------------------------------------
# Внутри docker-сети хост Redis — это имя сервиса 'redis'.
# Локально (без Docker) используйте redis://localhost:6379.
REDIS_URL=redis://redis:6379

# -----------------------------------------------------------------------------
# S3-совместимое хранилище медиа (MinIO локально, Timeweb/AWS в проде)
# -----------------------------------------------------------------------------
# Учётные данные администратора MinIO (контейнер minio в docker-compose).
# Это же логин/пароль входа в веб-консоль MinIO (порт :9001).
MINIO_ROOT_USER=minioadmin
# ВНИМАНИЕ: замените на надёжный пароль перед боевым запуском (мин. 8 символов).
MINIO_ROOT_PASSWORD=change-me-minio-password
# Адрес S3-эндпоинта. Внутри docker-сети — http://minio:9000.
S3_ENDPOINT=http://minio:9000
# Регион (для MinIO обычно us-east-1).
S3_REGION=us-east-1
# Ключ доступа (для MinIO совпадает с MINIO_ROOT_USER).
S3_ACCESS_KEY=minioadmin
# Секретный ключ (для MinIO совпадает с MINIO_ROOT_PASSWORD; НЕ хранить в репозитории).
S3_SECRET_KEY=change-me-minio-password
# Имя бакета для файлов магазина.
S3_BUCKET=admik-media
# Публичный URL, по которому отдаются загруженные файлы.
# Боевой (два домена): медиа отдаётся через Caddy на поддомене Admik по HTTPS —
#   https://${ADMIN_DOMAIN}/media/admik-media
# Caddy на ADMIN_DOMAIN: handle_path /media/* стрипает /media и проксирует
# остаток (/admik-media/<key>) в minio:9000 — это path-style адрес объекта.
# ВАЖНО: первый сегмент после /media ДОЛЖЕН совпадать с S3_BUCKET (admik-media).
# Итоговый публичный URL объекта = S3_PUBLIC_URL + "/" + key (см. lib/storage/s3.ts).
# Локально (без домена) можно отдавать напрямую с порта MinIO:
#   S3_PUBLIC_URL=http://localhost:9000/admik-media
S3_PUBLIC_URL=https://admin.example.com/media/admik-media

# -----------------------------------------------------------------------------
# Деплой и smoke-проверка готовности (Этап 6, 6.1; scripts/smoke.sh, deploy.sh)
# -----------------------------------------------------------------------------
# Базовый URL стенда, против которого smoke шлёт HTTP-проверки. Локально/в
# docker оставьте http://localhost (Caddy слушает :80). Для боевого домена
# укажите https://ВАШ_ДОМЕН (тогда проверяется реальный публичный адрес).
SMOKE_BASE_URL=http://localhost
# Сколько попыток делать на КАЖДЫЙ адрес, пока стек поднимается. По умолчанию 30.
SMOKE_RETRIES=30
# Пауза между попытками в секундах. По умолчанию 2 (30×2 ≈ 60с ожидания).
SMOKE_RETRY_DELAY=2
# Запускать smoke автоматически в конце init-shop.sh? true — да; иначе скрипт
# лишь печатает подсказку `make smoke`. По умолчанию false (внутри контейнера
# app может не быть curl / сетевого доступа к публичному адресу).
RUN_SMOKE=false

# -----------------------------------------------------------------------------
# Бэкапы БД и медиа (Этап 6, 6.2; scripts/backup.sh, restore-drill.sh; ADR-015)
# -----------------------------------------------------------------------------
# Том Docker — НЕ бэкап. Сервис `backup` (docker-compose) раз в сутки делает
# дамп БД (pg_dump) + зеркало медиа (mc mirror) в том backups, раз в неделю —
# учебное восстановление (restore-drill). Расписания — в формате cron (5 полей).
#
# Когда делать ежесуточный бэкап. По умолчанию 03:00 каждый день.
BACKUP_CRON=0 3 * * *
# Когда запускать restore-drill (проверку восстановления). По умолчанию вс 04:00.
BACKUP_DRILL_CRON=0 4 * * 0
# Сколько дней хранить дампы/зеркала; старше — удаляются. По умолчанию 14.
BACKUP_RETENTION_DAYS=14
# (опционально) Offsite-выгрузка бэкапов в ВНЕШНЕЕ приватное хранилище —
# alias rclone/mc БЕЗ хардкода провайдера (Timeweb/AWS/Backblaze/…). Пусто =
# только локальный том backups. Креды удалённого хранилища задаются настройкой
# самого rclone/mc, не в этом файле. Пример: BACKUP_OFFSITE_REMOTE=offsite/admik-backups
BACKUP_OFFSITE_REMOTE=

# -----------------------------------------------------------------------------
# Логи, мониторинг и алерты (Этап 6, 6.3; lib/logger.ts, healthcheck-monitor.sh)
# -----------------------------------------------------------------------------
# Приложение пишет структурные JSON-логи в stdout (одна строка = одно событие),
# их собирает Docker logging-драйвер (см. docker-compose.yml: ротация json-file).
#
# Минимальный уровень логов: debug | info | warn | error (по возрастанию). В prod
# держите info; debug — только при отладке (шумно). По умолчанию info.
LOG_LEVEL=info
# Человекочитаемый вывод логов вместо чистого JSON (удобно в dev-консоли). В prod
# оставляйте false — JSON парсится агрегаторами. По умолчанию false.
LOG_PRETTY=false
#
# Webhook для алертов мониторинга (health down / диск >90%). Подходит входящий
# webhook Telegram-бота или Slack. ПУСТО → алерты только в лог (сервис не падает).
# Telegram: https://api.telegram.org/bot<ТОКЕН>/sendMessage?chat_id=<ID>
# Slack:    https://hooks.slack.com/services/XXX/YYY/ZZZ
ALERT_WEBHOOK_URL=
#
# Параметры внешнего монитора (scripts/healthcheck-monitor.sh; читает ТОЛЬКО bash,
# в приложении не используются). Адрес для проверки доступности (публичный или
# внутренний). По умолчанию http://localhost/api/health.
HEALTHCHECK_URL=http://localhost/api/health
# Сколько подряд неудачных проверок до отправки алерта. По умолчанию 3.
HEALTHCHECK_FAILS_THRESHOLD=3

# -----------------------------------------------------------------------------
# Обновление без простоев (Этап 6, 6.4; scripts/update.sh; §6.4, ADR-015)
# -----------------------------------------------------------------------------
# update.sh: pull → build → бэкап → check-migrations → миграции → up -d → health-gate
# → откат при провале. Все параметры читает ТОЛЬКО bash (в приложении не нужны).
#
# Git-ref/тег для деплоя. Пусто → git pull текущей ветки (fast-forward).
# Пример: UPDATE_REF=v1.2.3
UPDATE_REF=
# Health-gate использует HEALTHCHECK_URL (см. выше) с авто-добавлением ?deep=1.
# Число попыток health-gate после пересоздания app. По умолчанию 30.
UPDATE_HEALTH_RETRIES=30
# Пауза между попытками health-gate в секундах. По умолчанию 2 (≈60с ожидания).
UPDATE_HEALTH_TIMEOUT=2
# Пропустить обязательный бэкап перед миграциями (true). НЕ рекомендуется —
# только для тестовых стендов. По умолчанию пусто (бэкап делается всегда).
UPDATE_SKIP_BACKUP=

# -----------------------------------------------------------------------------
# Модули платформы
# -----------------------------------------------------------------------------
# Список включённых модулей через запятую: catalog, orders, cdek, cms.
# Если переменная не задана — включены все модули.
ADMIK_MODULES=catalog,orders,cdek,cms

# -----------------------------------------------------------------------------
# Демо-данные каталога (опционально)
# -----------------------------------------------------------------------------
# true — наполнить демо-каталогом для ознакомления (нейтральные примерные
# категории/товары/варианты/остатки, db/seed/demo-catalog.sql). По умолчанию
# false: боевой магазин стартует с пустым каталогом без демонстрационного «мусора».
# Накат идемпотентен (повтор безопасен).
SEED_DEMO_CATALOG=false

# -----------------------------------------------------------------------------
# Storefront API — публичный read-каталог для внешних SPA-витрин (ADR-008, docs/06 §6)
# -----------------------------------------------------------------------------
# Доступ витрины предоставляется если совпал API-ключ ИЛИ Origin из списка ниже.
# Если ОБА параметра пусты — MOCK-режим: доступ открыт всем (для demo-витрины),
# в консоль выводится одноразовое предупреждение. Для боевого магазина задайте
# ключи и/или разрешённые домены.
#
# Список API-ключей через запятую — ими Admik ВАЛИДИРУЕТ входящие запросы витрины.
# Формы: «ключ» либо «домен:ключ» (домен — подсказка, проверяется именно ключ).
# Витрина шлёт ключ в заголовке X-Storefront-Key (или X-Api-Key). Пример:
#   STOREFRONT_API_KEYS=shop1.example.com:sk_live_xxx,gangauto.example.com:sk_live_yyy
#
# ⚠ БОЕВОЙ ДЕПЛОЙ со встроенной витриной storefront. Как только задан
# STOREFRONT_ALLOWED_ORIGINS, СЕРВЕРНЫЕ запросы витрины (SSR из контейнера
# storefront, без Origin-заголовка) получают от API 401 — Origin-авторизация
# работает только для БРАУЗЕРНЫХ запросов. Чтобы SSR-каталог витрины получал
# данные, задайте ОБЩИЙ ключ в ДВУХ местах с ОДИНАКОВЫМ значением:
#   STOREFRONT_API_KEY=<key>            (ниже — витрина шлёт его server-side)
#   STOREFRONT_API_KEYS=storefront:<key> (здесь — Admik этим ключом валидирует)
# Значение <key> — длинная случайная строка (напр. `openssl rand -hex 32`),
# одинаковая в обеих переменных. Реальный ключ — только в .env (.gitignore).
STOREFRONT_API_KEYS=
# Разрешённые Origin витрин через запятую (scheme://host[:port]). Используются
# для CORS и как альтернативный способ авторизации (без ключа). Для встроенной
# витрины магазина на ОДНОМ VPS это apex и www домена магазина:
STOREFRONT_ALLOWED_ORIGINS=https://${SHOP_DOMAIN},https://www.${SHOP_DOMAIN}

# -----------------------------------------------------------------------------
# Встроенная витрина магазина (сервис storefront в docker-compose)
# -----------------------------------------------------------------------------
# Витрина собирается из соседнего каталога ./storefront и поднимается отдельным
# контейнером на том же VPS (порт 3000, наружу не публикуется — только через
# Caddy на SHOP_DOMAIN). См. docs/13, docs/09.
#
# Публичный адрес API Admik для КЛИЕНТСКОГО бандла витрины (checkout,
# автокомплит городов СДЭК). Это build-arg: значение «впекается» в сборку
# Next.js, поэтому укажите ПУБЛИЧНЫЙ адрес поддомена Admik (НЕ внутренний
# app:3000 — он недоступен из браузера). Серверные запросы витрины ходят на
# http://app:3000 внутри docker-сети (ADMIK_API_URL задаётся в compose).
NEXT_PUBLIC_ADMIK_API_URL=https://${ADMIN_DOMAIN}
# Ключ витрины для SERVER-SIDE запросов (SSR) к API Admik. Контейнер storefront
# шлёт его в заголовке X-Storefront-Key. Это НЕ NEXT_PUBLIC-переменная — в
# браузерный бандл она НЕ попадает (только серверный код витрины её читает).
# Пусто → доступ по STOREFRONT_ALLOWED_ORIGINS / mock; но при заданных
# ALLOWED_ORIGINS серверные (SSR) запросы без ключа получают 401 — SSR-каталог
# не наполнится. Для боевого деплоя задайте ОБЩИЙ ключ: значение здесь ДОЛЖНО
# совпадать с ключом в STOREFRONT_API_KEYS=storefront:<key> (см. блок выше).
#   Пример: STOREFRONT_API_KEY=<key>  ⇆  STOREFRONT_API_KEYS=storefront:<key>
STOREFRONT_API_KEY=
# Закрыть витрину от поисковой индексации. Читается в рантайме (НЕ build-arg):
# при значении 1/true все страницы отдают <meta robots="noindex, nofollow>, а
# robots.txt — Disallow: /. Задайте 1 для ТЕСТОВОГО/staging стенда (закрыть от
# индексации). Оставьте ПУСТЫМ для боевого магазина клиента (индексация открыта).
STOREFRONT_NOINDEX=
# Детерминированное имя образа витрины (для честного отката, как APP_IMAGE).
# Переопределять обычно не нужно.
STOREFRONT_IMAGE=admik-storefront:current

# -----------------------------------------------------------------------------
# Брендинг магазина
# -----------------------------------------------------------------------------
# Название магазина (отображается в админке).
SHOP_NAME=Мой магазин
# URL логотипа магазина.
SHOP_LOGO_URL=https://example.com/logo.svg

# -----------------------------------------------------------------------------
# Заказы (Этап 3, docs/07)
# -----------------------------------------------------------------------------
# Валюта магазина (форматирование цен). По умолчанию RUB.
SHOP_CURRENCY=RUB
# Порог бесплатной доставки: при сумме (после скидки) ≥ порога доставка = 0.
# 0 = выключено (для Gang Auto = 3000).
SHOP_FREE_DELIVERY_THRESHOLD=0
# Префикс человекочитаемого номера заказа: `ПРЕФИКС-ГОД-NNNNNN` (напр. GA → GA-2026-000123).
# Пусто = номер вида `2026-000123`.
SHOP_ORDER_PREFIX=

# -----------------------------------------------------------------------------
# СДЭК (Этап 4, docs/08). ТРИ режима — по заполненности ключей и базового URL:
#
#   1) MOCK (по умолчанию): CDEK_ACCOUNT/CDEK_SECRET ПУСТЫ → сеть не дёргается,
#      расчёт по формуле, ПВЗ из фикстур, фейковые uuid/трек. Для CI/demo.
#
#   2) ТЕСТОВЫЙ КОНТУР СДЭК (sandbox «edu») — боевого договора НЕ требует:
#        CDEK_BASE_URL=https://api.edu.cdek.ru
#        CDEK_TEST_MODE=true
#        CDEK_ACCOUNT=<тестовый client_id>
#        CDEK_SECRET=<тестовый client_secret>
#      Публичные тестовые client_id/client_secret публикует САМ СДЭК в офиц.
#      документации интеграции (раздел «тестовый аккаунт») — это НЕ ключи
#      владельца магазина. Вписываются СЮДА, в .env (.env в .gitignore — в
#      репозиторий НЕ коммитятся). В test-режиме пустой CDEK_WEBHOOK_IPS допустим
#      (webhook работает с предупреждением).
#
#   3) БОЕВОЙ: CDEK_BASE_URL=https://api.cdek.ru + боевые ключи ВЛАДЕЛЬЦА магазина
#      (подставляются только при развёртывании, НИКОГДА не в репозитории).
#
#   ⚠ Любые ключи СДЭК (включая тестовые) живут только в .env, не в репозитории.
# -----------------------------------------------------------------------------
# Базовый URL API. Боевой: https://api.cdek.ru; ТЕСТОВЫЙ контур: https://api.edu.cdek.ru.
CDEK_BASE_URL=https://api.cdek.ru
# client_id / client_secret СДЭК. ПУСТО → mock-режим. Для тестового контура —
# публичные тестовые ключи из документации СДЭК (см. блок выше, режим 2).
CDEK_ACCOUNT=
CDEK_SECRET=
# Тестовый контур СДЭК (true/false). true ⇒ sandbox-поведение: допускается пустой
# webhook IP-whitelist (bypass с предупреждением). Ставьте true ВМЕСТЕ с edu-URL.
CDEK_TEST_MODE=false
# Код города отправления (44 = Москва). Взаимоисключим с CDEK_SHIPMENT_POINT.
CDEK_FROM_LOCATION_CODE=44
# Код склада отправителя (если задан — используется вместо from_location).
CDEK_SHIPMENT_POINT=
# Тариф ПВЗ/постамата (склад-склад) по умолчанию.
CDEK_DEFAULT_TARIFF=136
# Тариф курьерской доставки «до двери» (склад-дверь). Курьер тарифицируется им,
# а не ПВЗ-тарифом (M4).
CDEK_DOOR_TARIFF=137
# Белый список тарифов через запятую (пусто = все).
CDEK_ALLOWED_TARIFFS=
# Отправитель (для создания отправлений).
CDEK_SENDER_NAME=
CDEK_SENDER_CONTACT_NAME=
CDEK_SENDER_PHONE=
CDEK_SENDER_EMAIL=
CDEK_SENDER_INN=
# Дефолтные габариты упаковки (вес — г, размеры — см); аналог cdek-dimensions.php.
CDEK_DEFAULT_WEIGHT_G=500
CDEK_DEFAULT_LENGTH_CM=30
CDEK_DEFAULT_WIDTH_CM=20
CDEK_DEFAULT_HEIGHT_CM=10
# Секрет ?key= для webhook СДЭК.
CDEK_WEBHOOK_SECRET=
# IP/CIDR whitelist webhook через запятую (пусто допустимо лишь в test-режиме).
CDEK_WEBHOOK_IPS=
# Доверять прокси-заголовку IP (за Caddy).
CDEK_WEBHOOK_TRUST_PROXY=false
# Секрет cron-роутов СДЭК (X-Cron-Secret / ?key=). Задайте длинную случайную
# строку, чтобы включить фоновые задачи СДЭК (создание отправлений, обновление
# статусов, уведомления). Пусто → cron-роуты выключены (503), сервис cron из
# docker-compose ничего не делает. Расписание задаётся в docker-compose.yml
# (сервис cron): create-pending — каждые 5 мин, refresh-active — каждый час,
# notify-stuck — ежедневно в 10:00.
CDEK_CRON_SECRET=
# Внутренний адрес приложения для cron-контейнера (по умолчанию http://app:3000
# в docker-сети). Меняйте только при нестандартной сети/портах.
CDEK_CRON_URL=http://app:3000
# Kill-switch авто-создания отправлений.
CDEK_CREATE_ENABLED=true

# -----------------------------------------------------------------------------
# Т-БАНК ИНТЕРНЕТ-ЭКВАЙРИНГ (Этап 7, docs/15). ТРИ режима по заполненности ключей:
#   1) MOCK (по умолчанию): TBANK_TERMINAL_KEY/TBANK_PASSWORD ПУСТЫ → сеть не
#      дёргается, Init возвращает фейковый PaymentId + внутренний PaymentURL
#      (demo-страница оплаты). Для CI/demo — заказ оформляется и «оплачивается»
#      без боевого терминала.
#   2) ТЕСТОВЫЙ КОНТУР (sandbox): TBANK_BASE_URL=https://rest-api-test.tinkoff.ru/v2
#      + тестовые TerminalKey/Password из ЛК Т-Бизнес (тестовый терминал). Тестовая
#      карта 4300 0000 0000 0777 / 11/22 / 123. IP добавить в whitelist тестовой
#      среды через чат в ЛК Т-Бизнес.
#   3) БОЕВОЙ: TBANK_BASE_URL=https://securepay.tinkoff.ru/v2 + боевые ключи.
#   ⚠ Любые ключи Т-Банка (включая тестовые) живут ТОЛЬКО в .env, не в репозитории.
# -----------------------------------------------------------------------------
# Базовый URL T-API. Боевой securepay / тестовый rest-api-test (см. блок выше).
TBANK_BASE_URL=https://securepay.tinkoff.ru/v2
# Идентификатор терминала / пароль терминала (подпись Token). ПУСТО → mock-режим.
TBANK_TERMINAL_KEY=
TBANK_PASSWORD=
# Стадийность: O — одностадийная (списание сразу), T — двухстадийная (hold→Confirm).
TBANK_PAY_TYPE=O
# Чек 54-ФЗ (true только если к терминалу подключена онлайн-касса). По умолч. выкл.
TBANK_RECEIPT_ENABLED=false
# СНО магазина для чека (osn|usn_income|usn_income_outcome|esn|patent). Пусто → без чека.
TBANK_TAXATION=
# Ставка НДС позиции по умолчанию (none|vat0|vat10|vat20|…).
TBANK_DEFAULT_TAX=none
# Абсолютный URL нашего webhook (Init.NotificationURL); иначе берётся из ЛК.
TBANK_NOTIFICATION_URL=
# Редиректы витрины при успехе/отказе оплаты (опц.).
TBANK_SUCCESS_URL=
TBANK_FAIL_URL=
# Доп. IP/CIDR whitelist webhook (csv); ГЛАВНАЯ защита — Token. Пусто допустимо.
TBANK_WEBHOOK_IPS=
# Доверять прокси-заголовку IP webhook (за Caddy).
TBANK_WEBHOOK_TRUST_PROXY=false
# Срок жизни ссылки/QR оплаты (минуты) → Init.RedirectDueDate.
TBANK_REDIRECT_DUE_MIN=60
